# Edward Environment Variables — copy to .env and fill in values

# =============================================================================
# REQUIRED
# =============================================================================

# Anthropic API Key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# DATABASE (optional — defaults shown)
# =============================================================================

# DATABASE_URL=postgresql://edward:edward@localhost:5432/edward

# =============================================================================
# LANGSMITH OBSERVABILITY (optional)
# =============================================================================

# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGCHAIN_PROJECT=edward

# =============================================================================
# TWILIO SMS & WHATSAPP (optional — enables SMS/WhatsApp messaging)
# =============================================================================

# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...
# TWILIO_WEBHOOK_URL=https://your-domain.com/api/webhook/twilio
# TWILIO_WHATSAPP_WEBHOOK_URL=https://your-domain.com/api/webhook/twilio/whatsapp

# =============================================================================
# WHATSAPP MCP BRIDGE (optional — requires whatsapp-mcp Go bridge)
# =============================================================================

# MCP_WHATSAPP_ENABLED=false
# MCP_WHATSAPP_SERVER_DIR=/path/to/whatsapp-mcp/whatsapp-mcp-server

# =============================================================================
# APPLE SERVICES MCP (optional — macOS only)
# =============================================================================

# MCP_APPLE_ENABLED=true

# =============================================================================
# WEB SEARCH (optional — enables Brave Search)
# =============================================================================

# BRAVE_SEARCH_API_KEY=BSA...

# =============================================================================
# HTML HOSTING (optional — enables hosted HTML pages)
# =============================================================================

# HTML_HOSTING_API_KEY=...
# HTML_HOSTING_URL=https://html.zyroi.com

# =============================================================================
# CUSTOM MCP SERVERS (optional — GitHub API for server search)
# =============================================================================

# GITHUB_TOKEN=ghp_...

# =============================================================================
# GITHUB MCP (optional — enables GitHub read/write via github-mcp-server binary)
# =============================================================================

# Fine-grained PAT: Contents:read, Issues:read+write, Pull requests:read+write
# Create at: GitHub → Settings → Developer Settings → Fine-grained tokens
# Both vars must have the same value — GITHUB_MCP_TOKEN is for reference,
# GITHUB_PERSONAL_ACCESS_TOKEN is what the binary expects in its environment.
# GITHUB_MCP_TOKEN=github_pat_...
# GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_...

# =============================================================================
# AUTHENTICATION (optional — auto-generates secure default if unset)
# =============================================================================

# JWT_SECRET_KEY=your-secret-key

# =============================================================================
# PUSH NOTIFICATIONS (optional — Web Push via VAPID)
# =============================================================================

# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_CONTACT_EMAIL=admin@localhost

# =============================================================================
# FILE STORAGE (optional — defaults to ./storage)
# =============================================================================

# FILE_STORAGE_ROOT=./storage
